# IQ Option - NUNCA subas .env a Git. Usa variables de entorno.
# Copia este archivo a .env y completa con tus datos.

# Si Binance da error 451 (región bloqueada), usa Bybit en su lugar:
# USE_BYBIT=1

# O usa un proxy para Binance:
# HTTPS_PROXY=http://tu-proxy:puerto

IQ_OPTION_EMAIL=tu_email@ejemplo.com
IQ_OPTION_PASSWORD=tu_contraseña

# URL de login (por defecto lleva al traderoom)
IQ_OPTION_LOGIN_URL=https://login.iqoption.com/es/login?redirect_url=traderoom%2F

# Broker visible (false = abre ventana del navegador, util si el scraping falla en headless)
# BROKER_HEADLESS=false


